# Server Configuration
PORT=8080
NODE_ENV=production

# Database Connection (Direct URL or separate parameters)
# In Docker Compose, the database host matches the service name: "db"
DATABASE_URL=postgres://postgres:your_secure_password@db:5432/stuntdruk

# Database connection parameters (optional, if NOT using DATABASE_URL)
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=stuntdruk
DB_PORT=5432

# Security & Authentication
JWT_SECRET=replace_this_with_a_long_random_string_in_production
JWT_EXPIRES_IN=24h
